#import "/formatting.typ": *

#recipe(
  title: "Basic Bread",
  description: [A horrifically unappetizing loaf of basic, basic bread. Perfect for
    breadcrumbs.],
  panel-width: 13em,
  yield: "1 loaf, 9\"×5\"",
  refs: <kair_breads>,
)[
  - 57g milk #aside[1/4 cup]
  - 18g butter, molten #aside[1 1/4 tbsp.]
  - 19g sugar #aside[1 1/2 tbsp.]
  - 6g salt #pause[1 tsp.]
  - 7g yeast #aside[2 1/4 tsp.]
  - 177g warm water, \~40-45°C #pause[3/4 cups, 105--115°F]
  - 350g all-purpose flour#aside[2 3/4--3 cups]
][
  + SETUP mixer with Danish hook attachment.
  + MIX each group until combined, low speed:~
    + Milk, sugar, salt, & butter.
    + Yeast & warm water.
    + Flour.
  + COVER and rest until doubled. #pause[\~1 hr.]
  + PREHEAT oven to 190°C (400°F). #pause[\~10 min.]
  + BAKE until set. #pause[30 min. uncovered]
]
