#import "/formatting.typ": *

= Sourdough Bread

#columns(2)[
  #show list.item: set text(style: "italic")

  - 90g sourdough starter
  - 300g water, lukewarm
  - 350g bread flour
  - 100g einkorn flour
  - 8g salt

  *Yields 1 loaf.*

  #colbreak()

  + Mix in wet ingredients.
  + Mix in dry ingredients.
  + Cover bowl. Let rise 8-24 hours.
  + Preheat oven to 200°C (400°F).
  + Pour dough into cast iron.
  + Bake for 30-45 minutes, or until knives come out clean.
]
