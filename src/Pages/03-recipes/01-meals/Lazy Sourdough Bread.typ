#import "/formatting.typ": *

#recipe(
  title: "Lazy Sourdough Bread",
  description: [Not the best loaf, but among the easiest (at least for sourdough).],
  yield: [1 large loaf#footnote[My large loaf pan is 11"×5" and holds up to 4ℓ.]],
  panel-width: 14.5em,
)[
  - 90g sourdough starter #aside[3/8 cup]
  - 300g water, lukewarm #pause[1 1/4 cup]
  - 350g bread flour #aside[3 cups]
  - 100g einkorn flour #aside[3/4 cup]
  - 9g salt #aside[1/2 tbsp.]
][
  + MIX water and flours in bowl.
  + COVER with damp towel. Rest. #pause[30-60 min.]
  + MIX starter and salt into bowl.
  + COVER anew. Rest. #pause[8-24 hr.]
  + PREHEAT oven to 200°C. #pause[\~10 min., 390°F]
  + POUR dough into cast iron.
  + BAKE until set. #pause[\~30-45 min.]
]
