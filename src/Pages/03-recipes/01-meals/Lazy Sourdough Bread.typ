#import "/formatting.typ": *

#recipe(title: "Lazy Sourdough Bread", yield: "1 loaf, 9\"×5\"")[
  - 90g sourdough starter #aside[3/8 cup]
  - 300g water, lukewarm #pause[1 1/4 cup]
  - 350g bread flour #aside[3 cups]
  - 100g einkorn flour #aside[3/4 cup]
  - 8g salt #aside[1/2 tsp.]
][
  + Mix in wet ingredients.
  + Mix in dry ingredients.
  + Cover bowl. Let rise 8-24 hours.
  + Preheat oven to 200°C. #aside[\~10 min., 390°F]
  + Pour dough into cast iron.
  + Bake for 30-45 minutes, or until knives come out clean.
]
