#import "/formatting.typ": *

#recipe(title: "Sugar Cookies")[
  - 365g all-purpose flour #aside[2 3/4 cup]
  - 6g baking soda #aside[1 tsp.]
  // TODO: Does this need to be baking powder? Can we try 1/4 tsp. baking soda and 1/2 tsp.
  // white vinegar instead? How about lemon juice instead, for flavor?
  - 2g baking powder #aside[1/2 tsp.]
  - 225g butter, softened #aside[1 cup]
  - 315g cups white sugar #aside[1 1/2]
  - 60g egg #aside[1 large egg]
  - 5g vanilla extract #aside[1 tsp.]

][
  + PREHEAT oven to 190°C. #aside[375°F]
  + MIX in stages: sugar, butter; egg, vanilla; flour, baking soda, baking powder.
  + ROLL small, depressed balls on baking sheet.
  + BAKE. #pause[8-10 min.]
  + COOL before serving. #pause[3-5 min.]
]


