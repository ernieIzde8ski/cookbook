#import "/formatting.typ": *

#recipe(title: "Spicy Hummus", panel-width: 45%)[
  // TODO: metric
  - 1/4 cup tahini
  - 27g olive oil #aside[2 tbsp.]
  - 1 tbsp. lemon juice
  - 1 tbsp. minced garlic
  - 1/2 tsp. ground cumin#Fn.cumin
  - 1/2 tsp. salt
  - 1/4 tsp. sesame oil
  - Hot pepper, to taste#footnote[~Habaneros & ghost peppers work great here. Fun for the
      whole family. Maybe not the whole family. Fun all the same.]
  - 425g garbanzo beans, cooked #aside[15 oz.]
  - 30-60g cold water#footnote[~More water #sym.arrow.r.double fluffier hummus.]
    #aside[2-4 tbsp.]

][
  + SET aside garbanzos, water.
  + BLEND#footnote[Highly recommend a food processor.] remaining ingredients until smooth.
  + ADD garbanzos; continue blending.
  + ADD water; continue blending.
  + CHILL in refrigerator.
]
