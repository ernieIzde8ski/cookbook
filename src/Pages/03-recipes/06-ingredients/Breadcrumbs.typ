#import "/formatting.typ": *

#recipe(title: "Breadcrumbs")[- Bread][
  + MASH bread by hand into bowl.
  + GRIND crumbs in food processor, high speed.
]

#recipe(title: "Panko Breadcrumbs")[- Bread#footnote[I typically use stale bread here.]][
  + PREHEAT oven to 120°C. #aside[250°F]
  + (Optional) SLICE crust off bread.#footnote[Skipping this step gives you tanned panko
      breadcrumbs.]
  + MASH bread by hand into bowl.
  + GRIND crumbs in food processor, high speed.
  + BAKE on sheet. #pause[20-30 min]
  + COOL on wire rack. #pause[\~1 hr.]
]

